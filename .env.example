# ================================
# KDPM Medical Association
# Member Management System
# Environment Configuration
# ================================

# MongoDB Connection
MONGODB_URI=mongodb+srv://apmkopdistricts_db_user:<db_password>@kdpm.x19is2r.mongodb.net/?appName=KDPM

# JWT Configuration
JWT_SECRET=kdpm_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=24h

# Admin Credentials (single admin login)
ADMIN_EMAIL=admin@kdpm.org
ADMIN_PASSWORD=admin123

# Brevo (Sendinblue) SMTP Configuration
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=your_brevo_smtp_login_email
BREVO_SMTP_PASS=your_brevo_smtp_password
EMAIL_FROM=noreply@kdpm.org

# Google Sheets API Configuration
GOOGLE_SHEET_ID=your_google_sheet_id_here
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----"

# Server
PORT=5000
